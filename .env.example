# Email delivery and subscriber segmentation
BUTTONDOWN_API_KEY=

# Protects cron, sync, preview, and manual-send endpoints
CRON_SECRET=

# MySQL storage for articles, papers, intelligence, and subscribers
# (replaces Upstash Redis — teacher requirement: no Redis)
# Run `mysql -uroot -p < scripts/schema.sql` once to create the schema.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_web

# ─── Metaso (秘塔) AI 搜索 ───
# 由 /api/cron/mita-media 使用，每周（北京时间周日 18:00）刷新传媒板块情报。
# 在 https://metaso.cn/search-api/api-keys 获取 API Key。
MITA_API_KEY=
# 可选：覆盖秘塔 API 地址（默认 https://metaso.cn/api/v1/search）
MITA_API_BASE=
# 可选：每周刷新时的并发数与每词返回条数
MITA_CONCURRENCY=4
MITA_SIZE=10

# Optional legacy integrations
RESEND_API_KEY=
STORAGE_MONTHS=
INTELLIGENCE_WORKSPACE_ROOT=
MEDIA_INTEL_PATH=
MEDIA_WEEKLY_PATH=
PE_INTEL_PATH=

# ─── 识澜·观潮 (Topic Radar) ───
# 通用 LLM 抽象层（OpenAI-compatible，不绑定厂商）。
# 本阶段默认 LLM_PROVIDER=mock，无需任何 Key 即可跑通测试与管线。
# 接入真实模型时：把 LLM_PROVIDER 改为 openai-compatible（或 deepseek），
# 并填写 LLM_API_KEY / LLM_BASE_URL / LLM_MODEL。例如 DeepSeek：
#   LLM_PROVIDER=openai-compatible
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_API_KEY=sk-xxxx
#   LLM_MODEL=deepseek-chat
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_MS=30000

# 观潮评分与扫描配置（均有合理默认值，可覆盖）
TOPIC_RADAR_ENABLED=true
TOPIC_RADAR_LOOKBACK_DAYS=14
TOPIC_RADAR_BASELINE_DAYS=30
TOPIC_RADAR_MAX_ARTICLES=2000
TOPIC_RADAR_MIN_CLUSTER_SIZE=2
# 低于该分不展示（也作为是否生成选题卡的门槛）
TOPIC_RADAR_MIN_DISPLAY_SCORE=50
# 达到该分视为“重点选题”
TOPIC_RADAR_PRIORITY_SCORE=80
# 同一话题卡片重新生成的冷却时间（小时）与触发阈值
TOPIC_CARD_REGENERATE_HOURS=24
TOPIC_CARD_MIN_NEW_ARTICLES=2
# 评分权重（合计应为 1.0，由上层负责归一化）
TOPIC_SCORE_TREND_WEIGHT=0.25
TOPIC_SCORE_AUTHORITY_WEIGHT=0.15
TOPIC_SCORE_DIVERSITY_WEIGHT=0.10
TOPIC_SCORE_LOCAL_WEIGHT=0.20
TOPIC_SCORE_COMPETITOR_GAP_WEIGHT=0.15
TOPIC_SCORE_NEWS_VALUE_WEIGHT=0.15

# 观潮手动运行 / 定时任务的 API 基址（CLI 与 CI 调用 /api/topics/run 用）
# 本地开发：http://localhost:3000 ；部署后填生产域名。
TOPIC_RADAR_API_URL=http://localhost:3000
